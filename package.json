{
  "name": "intent-link",
  "version": "1.0.8",
  "description": "User target prediction library",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "nextjs",
    "react",
    "prefetch",
    "performance",
    "intent",
    "target prediction"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Intent-Link/intent-link-npm.git"
  },
  "bugs": {
    "url": "https://github.com/Intent-Link/intent-link-npm/issues"
  },
  "homepage": "https://github.com/Intent-Link/intent-link-npm#readme",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
