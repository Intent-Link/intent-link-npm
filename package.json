{
  "name": "intent-link",
  "version": "1.0.13",
  "description": "User target prediction library",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "check": "npm run test && npm run build",
    "check:all": "npm run check && npm run test:e2e",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "nextjs",
    "react",
    "prefetch",
    "performance",
    "intent",
    "target prediction"
  ],
  "author": "Uzafir Ahmad Rafaq",
  "contributors": [
    "Muaz Hassan",
    "Ali Muzaffar"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Intent-Link/intent-link-npm.git"
  },
  "bugs": {
    "url": "https://github.com/Intent-Link/intent-link-npm/issues"
  },
  "homepage": "https://intentlink.dev/en",
  "funding": {
    "type": "patreon",
    "url": "https://www.patreon.com/c/IntentLink"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "esbuild": "0.28.1",
    "jsdom": "^24.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "next": ">=13.0.0 <17.0.0",
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
